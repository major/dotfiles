{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "packageRules": [
    {
      "description": "Automerge chezmoi external tool updates",
      "matchManagers": [
        "custom.regex"
      ],
      "matchFileNames": [
        ".chezmoiexternal.toml"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": false
    }
  ],
  "customDatasources": {
    "coderabbit-cli": {
      "defaultRegistryUrlTemplate": "https://cli.coderabbit.ai/releases/latest/VERSION",
      "format": "plain"
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.chezmoiexternal\\.toml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+extractVersion=(?<extractVersion>\\S+))?\\s*\\n\\s*url\\s*=\\s*\"[^\"]*?[-/]v?(?<currentValue>[\\d.]+)[^\"]*\""
      ],
      "versioningTemplate": "semver"
    }
  ]
}
