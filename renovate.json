{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>major/renovate-config"
  ],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "packageRules": [
    {
      "description": "Disable cooldown period for this repo",
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ],
      "minimumReleaseAge": null
    },
    {
      "description": "Automerge chezmoi external tool updates",
      "matchManagers": [
        "custom.regex"
      ],
      "matchFileNames": [
        ".chezmoiexternal.toml"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": false
    },
    {
      "description": "Require review for opencode and opencode plugin updates",
      "matchManagers": [
        "custom.regex"
      ],
      "matchFileNames": [
        ".chezmoiexternal.toml"
      ],
      "matchPackageNames": [
        "anomalyco/opencode",
        "opencode-codebase-index",
        "openrtk",
        "context-mode",
        "opencode-lcm",
        "obra/superpowers"
      ],
      "automerge": false,
      "platformAutomerge": false
    }
  ],
  "customDatasources": {
    "coderabbit-cli": {
      "defaultRegistryUrlTemplate": "https://cli.coderabbit.ai/releases/latest/VERSION",
      "format": "plain"
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.chezmoiexternal\\.toml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+extractVersion=(?<extractVersion>\\S+))?\\s*\\n\\s*url\\s*=\\s*\"[^\"]*?[-/]v?(?<currentValue>\\d+(?:\\.\\d+)*(?:[-+][A-Za-z0-9.-]+)?)[^\"]*\""
      ],
      "versioningTemplate": "semver"
    }
  ]
}
