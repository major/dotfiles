# Host-specific and custom kitty overrides
# This file is included at the end of kitty.conf and overrides defaults.
#
# This is a chezmoi template (local.conf.tmpl). To edit:
#   1. Edit the source: chezmoi edit ~/.config/kitty/local.conf
#   2. Apply changes:   chezmoi apply ~/.config/kitty/
#
# Go template expressions are evaluated per host at apply time.
# Use .chezmoi.hostname to vary settings by machine.

# Load theme here (not in kitty.conf) so theme colors override defaults
include theme.conf

font_family      family="Hack"
font_size {{ if eq .chezmoi.hostname "zorro" }}10{{ else }}9{{ end }}

# Prevent descender clipping (g, j, p, q, y)
modify_font cell_height 104%

shell /usr/bin/zsh

map shift+page_up scroll_page_up
map shift+page_down scroll_page_down

# Make numpad Enter send literal newline (LF) instead of CR like regular Enter
map kp_enter send_text all \x0a
