{
    "layer": "top",
    "position": "bottom",
    "height": 30,
    "modules-left": [
        "hyprland/workspaces"
    ],
    "hyprland/workspaces": {
        "all-outputs": false
    },
    "modules-center": [
        "clock#eu",
        "clock#home",
        "custom/weather",
        "custom/nws-alerts"
    ],
    "modules-right": [
        "battery",
        "custom/uname",
        "memory",
        "cpu",
        "temperature",
        "temperature#gpu",
        "disk",
        "pulseaudio",
        "tray"
    ],
    "custom/weather": {
        "exec": "~/bin/weather",
        "return-type": "json",
        "format": "{}",
        "interval": 900
    },
    "custom/nws-alerts": {
        "exec": "~/bin/nws-alerts",
        "return-type": "json",
        "format": "{}",
        "interval": 900
    },
    "custom/uname": {
        "exec": "uname -r | sed 's/\\.fc.*//'",
        "format": " {}",
        "interval": 3600
    },
    "custom/egauge": {
        "exec": "~/bin/egauge",
        "format": "{}",
        "interval": 300
    },
    "custom/amdups": {
        "exec": "~/bin/ups_wattage",
        "format": " {}W"
    },
    "custom/firewallups": {
        "exec": "~/bin/ups_wattage_firewall",
        "format": " {}W"
    },
    "memory": {
        "interval": 30,
        "format": " {used:0.1f}G"
    },
    "cpu": {
        "interval": 10,
        "format": " {avg_frequency:0.2f}GHz",
        "max-length": 10
    },
    "temperature": {
        "thermal-zone": 0,
{{- if eq .chezmoi.hostname "zorro" }}
        "hwmon-path": "/sys/class/hwmon/hwmon8/temp1_input",
{{- else if eq .chezmoi.hostname "amdbox" }}
        "hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
{{- end }}
        "critical-threshold": 80,
        "format": " {temperatureC}°C",
        "interval": 5
    },
    "temperature#gpu": {
{{- if eq .chezmoi.hostname "zorro" }}
        "hwmon-path": "/sys/class/hwmon/hwmon7/temp1_input",
{{- else if eq .chezmoi.hostname "amdbox" }}
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
{{- end }}
        "critical-threshold": 90,
        "format": " {temperatureC}°C",
        "interval": 5
    },
    "disk": {
        "interval": 30,
        "format": " {free}",
        "path": "/"
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": false,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "",
            "unlocked": ""
        }
    },
    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}",
        "format-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": [
                "",
                ""
            ]
        },
        "scroll-step": 1,
        "on-click": "pavucontrol"
    },
    "clock#eu": {
        "format": "{:%H:%M} 🇨🇿",
        "timezone": "Europe/Prague"
    },
    "clock#home": {
        "format": "{:%m/%d  🇺🇸 %H:%M:%S}",
        "interval": 1,
        "timezone": "America/Chicago"
    },
    "tray": {
        "icon-size": 14,
        "spacing": 5
    },
    "battery": {
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{power:0.1f}W {capacity}% {icon}",
        "format-icons": [
            "",
            "",
            "",
            "",
            ""
        ],
        "max-length": 25
    }
}
