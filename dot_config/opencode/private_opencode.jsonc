{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "instructions": [
    "/home/major/.config/opencode/AGENTS.md",
    "/home/major/.config/opencode/PERSONAL_INSTRUCTIONS.md",
  ],
  "small_model": "google-vertex-anthropic/claude-haiku-4-5@20251001",
  "agent": {
    "explore": {
      "model": "google-vertex-anthropic/claude-haiku-4-5@20251001"
    }
  },
  "lsp": true,
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen2.5:32b": {
          "name": "Qwen 2.5 32B"
        }
      }
    }
  },
  "mcp": {},
  "permission": {
    "external_directory": {
      "*": "ask",
      "/home/major/.agents/skills": "allow",
      "/home/major/.agents/skills/**": "allow",
      "/tmp": "allow",
      "/tmp/opencode": "allow",
      "/tmp/opencode/**": "allow",
      "/home/major/git/worktrees/**": "allow",
    },
    "websearch": "allow",
  },
  "plugin": [
    // renovate: datasource=npm depName=opencode-codebase-index
    "opencode-codebase-index@0.11.0",
    "file:///home/major/.local/share/opencode/plugins/superpowers/.opencode/plugins/superpowers.js",
    "file:///home/major/.local/share/opencode/plugins/ponytail/.opencode/plugins/ponytail.mjs",
    // renovate: datasource=npm depName=openrtk
    "openrtk@0.1.0",
    // renovate: datasource=npm depName=context-mode
    "context-mode@1.0.163",
    [
      // renovate: datasource=npm depName=opencode-lcm
      "opencode-lcm@0.14.4",
      {
        "interop": {
          "contextMode": true,
          "neverOverrideCompactionPrompt": true,
          "ignoreToolPrefixes": ["ctx_"],
        },
      },
    ],
  ],
}
