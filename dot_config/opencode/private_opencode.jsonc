{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "instructions": [
    "/home/major/.config/opencode/AGENTS.md",
    "/home/major/.config/opencode/PERSONAL_INSTRUCTIONS.md",
  ],
  "small_model": "anthropic/claude-haiku-4-5",
  "lsp": true,
  "mcp": {},
  "permission": {
    "external_directory": {
      "*": "ask",
      "/home/major/.agents/skills": "allow",
      "/home/major/.agents/skills/**": "allow",
      "/tmp": "allow",
      "/tmp/opencode": "allow",
      "/tmp/opencode/**": "allow",
      "/home/major/git/worktrees/**": "allow",
    },
    "websearch": "allow",
  },
  "plugin": [
    // renovate: datasource=npm depName=opencode-codebase-index
    "opencode-codebase-index@0.11.0",
    "file:///home/major/.local/share/opencode/plugins/superpowers/.opencode/plugins/superpowers.js",
    // renovate: datasource=npm depName=openrtk
    "openrtk@0.1.0",
    // renovate: datasource=npm depName=context-mode
    "context-mode@1.0.162",
    [
      // renovate: datasource=npm depName=opencode-lcm
      "opencode-lcm@0.14.4",
      {
        "interop": {
          "contextMode": true,
          "neverOverrideCompactionPrompt": true,
          "ignoreToolPrefixes": ["ctx_"],
        },
      },
    ],
  ],
}
