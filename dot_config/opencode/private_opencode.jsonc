{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "instructions": [
    "/home/major/.config/opencode/AGENTS.md",
    "/home/major/.config/opencode/PERSONAL_INSTRUCTIONS.md"
  ],
  "small_model": "anthropic/claude-haiku-4-5",
  "lsp": true,
  "mcp": {},
  "agent": {
    "explore": {
      "model": "anthropic/claude-haiku-4-5"
    }
  },
  "permission": {
    "external_directory": {
      "*": "ask",
      "/home/major/.config/opencode/skills": "allow",
      "/home/major/.config/opencode/skills/**": "allow",
      "/tmp": "allow",
      "/tmp/opencode": "allow",
      "/tmp/opencode/**": "allow",
      "/home/major/git/worktrees/**": "allow"
    },
    "websearch": "allow"
  },
  "plugin": [
    //"oh-my-openagent@latest",
    //"@tarquinen/opencode-dcp@latest",
    "file:///home/major/.local/share/opencode/plugins/opencode-codebase-index/dist/index.js",
    "file:///home/major/.local/share/opencode/plugins/superpowers/.opencode/plugins/superpowers.js",
    "file:///home/major/.local/share/opencode/plugins/openrtk/lib/index.js",
    "file:///home/major/.local/share/opencode/plugins/context-mode/build/adapters/opencode/plugin.js",
    [
      "file:///home/major/.local/share/opencode/plugins/opencode-lcm/dist/index.js",
      {
        "interop": {
          "contextMode": true,
          "neverOverrideCompactionPrompt": true,
          "ignoreToolPrefixes": ["ctx_"]
        }
      }
    ],
  ]
}
