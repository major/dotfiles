{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "instructions": [
    "/home/major/.config/opencode/AGENTS.md",
    "/home/major/.config/opencode/PERSONAL_INSTRUCTIONS.md"
  ],
  "small_model": "anthropic/claude-haiku-4-5",
  "lsp": true,
  "mcp": {},
  "agent": {
    "explore": {
      "model": "anthropic/claude-haiku-4-5"
    }
  },
  "permission": {
    "external_directory": {
      "*": "ask",
      "/home/major/.config/opencode/skills": "allow",
      "/home/major/.config/opencode/skills/**": "allow",
      "/tmp": "allow",
      "/tmp/opencode": "allow",
      "/tmp/opencode/**": "allow",
      "/home/major/git/worktrees/**": "allow"
    },
    "websearch": "allow"
  },
  "plugin": [
    //"oh-my-openagent@latest",
    //"@tarquinen/opencode-dcp@latest",
    "opencode-codebase-index",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "openrtk",
    "context-mode",
    [
      "opencode-lcm",
      {
        "interop": {
          "contextMode": true,
          "neverOverrideCompactionPrompt": true,
          "ignoreToolPrefixes": ["ctx_"]
        }
      }
    ],
  ]
}
