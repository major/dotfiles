{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",

  // Master switch to enable or disable the DCP plugin entirely
  "enabled": true,

  // Automatically update npm-installed DCP when a newer version is available.
  // Version-locked plugin specs (e.g. @tarquinen/opencode-dcp@3.1.0) are not updated.
  "autoUpdate": true,

  // Write debug logs to ~/.config/opencode/logs/dcp/
  "debug": false,

  // How much detail to show when pruning occurs: "off", "minimal", or "detailed"
  "pruneNotification": "detailed",

  // Where to show pruning notifications: "chat" (inline in conversation) or "toast" (system notification)
  "pruneNotificationType": "chat",

  // Slash command settings (/dcp sweep, /dcp context, etc.)
  "commands": {
    // Enable or disable all /dcp slash commands
    "enabled": true,
    // Extra tool names (or glob patterns like "mcp_*") to protect from /dcp sweep
    "protectedTools": []
  },

  // Manual mode disables autonomous context management.
  // Tools only run when you explicitly trigger them via /dcp commands.
  "manualMode": {
    // Start new sessions with manual mode enabled
    "enabled": false,
    // When manual mode is on, still run automatic cleanup (deduplication, purgeErrors)
    "automaticStrategies": true
  },

  // Protect recent tool outputs from being pruned for N turns after invocation
  "turnProtection": {
    // Enable turn-based protection
    "enabled": true,
    // Number of recent message turns to shield from pruning
    "turns": 4
  },

  // Experimental features that may change in future releases
  "experimental": {
    // Allow DCP to process subagent sessions (task-spawned agents)
    "allowSubAgents": true,
    // Enable user-editable prompt overrides in ~/.config/opencode/dcp-prompts/
    "customPrompts": false
  },

  // Glob patterns for file paths to protect from pruning.
  // Matches tool parameters.filePath (read/write/edit calls).
  // Example: ["**/AGENTS.md", "**/*.config.ts"]
  "protectedFilePatterns": ["**/AGENTS.md", "**/PERSONAL_INSTRUCTIONS.md"],

  // Unified compression tool and behavior settings
  "compress": {
    // "range": compress contiguous message spans into block summaries
    // "message" (experimental): compress individual raw messages independently
    "mode": "range",

    // Permission for the compress tool: "allow" (no prompt), "ask" (confirm each time), "deny" (tool not registered)
    "permission": "allow",

    // Show the compression summary content in a chat notification
    "showCompression": false,

    // Let active summary tokens extend the effective maxContextLimit,
    // so summaries don't count against the nudge threshold
    "summaryBuffer": true,

    // Soft upper threshold (tokens). Above this, DCP sends strong compression nudges
    // every nudgeFrequency fetches. Accepts a number or "X%" of model context window.
    "maxContextLimit": "88%",

    // Soft lower threshold (tokens). Below this, turn/iteration reminders are off
    // so compression is less likely. Accepts a number or "X%" of model context window.
    "minContextLimit": "33%",

    // Per-model override for maxContextLimit keyed by providerID/modelID.
    // Takes priority over the global maxContextLimit. Accepts number or "X%".
    // Example:
    // "modelMaxLimits": {
    //   "openai/gpt-5.3-codex": 120000,
    //   "anthropic/claude-sonnet-4.6": "80%"
    // },

    // Per-model override for minContextLimit keyed by providerID/modelID.
    // Takes priority over the global minContextLimit. Accepts number or "X%".
    // Example:
    // "modelMinLimits": {
    //   "openai/gpt-5.3-codex": 50000,
    //   "anthropic/claude-sonnet-4.6": "25%"
    // },

    // How often the context-limit nudge fires when above maxContextLimit
    // (1 = every LLM fetch, 5 = every 5th fetch)
    "nudgeFrequency": 5,

    // Start adding compression reminders after this many assistant messages
    // have elapsed since the last user message
    "iterationNudgeThreshold": 15,

    // How aggressively to nudge compression after user messages:
    // "strong" = more likely to compress, "soft" = less likely
    "nudgeForce": "soft",

    // Tool names (or glob patterns) whose completed outputs get appended
    // to the compression summary so they survive pruning
    "protectedTools": [],

    // Preserve text wrapped in <protect>...</protect> tags during compression
    "protectTags": true,

    // Keep your messages verbatim during compression (never prune user text).
    // Warning: large copy-pasted content in prompts will never be compressed away.
    "protectUserMessages": false
  },

  // Automatic pruning strategies that run without the compress tool
  "strategies": {
    // Remove duplicate tool calls (same tool name + same arguments), keeping only the latest
    "deduplication": {
      "enabled": true,
      // Tool names (or glob patterns) excluded from deduplication
      "protectedTools": []
    },
    // Prune the (potentially large) input content of errored tool calls after N turns.
    // Error messages themselves are preserved.
    "purgeErrors": {
      "enabled": true,
      // Number of turns before errored tool inputs are pruned
      "turns": 4,
      // Tool names (or glob patterns) excluded from error purging
      "protectedTools": []
    }
  }
}
