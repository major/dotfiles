{
  // Provider constraints:
  // - Anthropic models (haiku, sonnet, opus) via direct Anthropic API
  // - Avoid -fast variants (cost)
  // - Top tier: claude-opus-4-7, Mid tier: claude-sonnet-4-6, Fast tier: claude-haiku-4-5
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "disabled_hooks": [
    "comment-checker"
  ],
  "disabled_skills": [
    "git-master",
    "playwright"
  ],
  "git_master": {
    "commit_footer": "",
    "include_co_authored_by": false,
    "git_env_prefix": ""
  },
  "tmux": {
    "enabled": false,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40,
    "isolation": "inline"
  },
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "librarian": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "explore": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "multimodal-looker": {
      "model": "anthropic/claude-sonnet-4-6",
      "variant": "medium"
    },
    "prometheus": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },
    "metis": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "momus": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "sisyphus-junior": {
      "model": "anthropic/claude-sonnet-4-6"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },
    "ultrabrain": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "xhigh"
    },
    "deep": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "medium"
    },
    "artistry": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },
    "quick": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "unspecified-low": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "unspecified-high": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },
    "writing": {
      "model": "anthropic/claude-sonnet-4-6"
    }
  }
}
