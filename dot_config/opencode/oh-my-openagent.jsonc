{
  // Provider constraints:
  // - Anthropic models (haiku, sonnet, opus) via Google Vertex AI only
  // - OpenAI GPT models (direct)
  // - No access to minimax, grok, gemini, or other providers
  // - Claude Opus 4-7 not yet available on Vertex AI (pinned to 4-6)
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "disabled_hooks": [
    "comment-checker"
  ],
  "disabled_skills": [
    "git-master",
    "playwright"
  ],
  "git_master": {
    "commit_footer": "",
    "include_co_authored_by": false,
    "git_env_prefix": ""
  },
  "tmux": {
    "enabled": false,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40,
    "isolation": "inline"
  },
  "agents": {
    "sisyphus": {
      "model": "google-vertex-anthropic/claude-opus-4-6@default",
      "variant": "high"
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini-fast"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini-fast"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "prometheus": {
      "model": "google-vertex-anthropic/claude-opus-4-6@default",
      "variant": "max"
    },
    "metis": {
      "model": "google-vertex-anthropic/claude-opus-4-6@default",
      "variant": "max"
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "google-vertex-anthropic/claude-sonnet-4-6@default",
      "variant": "medium"
    },
    "sisyphus-junior": {
      "model": "google-vertex-anthropic/claude-sonnet-4-6@default",
      "variant": "medium"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "google-vertex-anthropic/claude-opus-4-6@default",
      "variant": "max"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "artistry": {
      "model": "google-vertex-anthropic/claude-opus-4-6@default",
      "variant": "max"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini"
    },
    "unspecified-low": {
      "model": "google-vertex-anthropic/claude-sonnet-4-6@default"
    },
    "unspecified-high": {
      "model": "google-vertex-anthropic/claude-opus-4-6@default",
      "variant": "max"
    },
    "writing": {
      "model": "google-vertex-anthropic/claude-sonnet-4-6@default"
    }
  }
}
